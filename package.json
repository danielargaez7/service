{
  "name": "@servicecore/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev:api": "NX_DAEMON=false NX_CLOUD=false nx build backend-api --configuration=development && node dist/apps/backend-api/main.js",
    "dev:dashboard": "NX_DAEMON=false NX_CLOUD=false CHOKIDAR_USEPOLLING=1 WATCHPACK_POLLING=true nx serve manager-dashboard --port=4200 --poll=1000",
    "dev:driver": "NX_DAEMON=false NX_CLOUD=false CHOKIDAR_USEPOLLING=1 WATCHPACK_POLLING=true nx serve driver-app --port=4201 --poll=1000",
    "dev:all": "concurrently -k -n API,DASH,DRIVER -c cyan,green,magenta \"npm:dev:api\" \"npm:dev:dashboard\" \"npm:dev:driver\"",
    "dev:demo": "TIMETREX_INTEGRATION_ENABLED=false npm run dev:all",
    "dev:stop": "lsof -ti:3000 -ti:4200 -ti:4201 | xargs kill -9",
    "demo:preflight": "node tools/demo-preflight.mjs",
    "generate:api-clients": "bash tools/generate-api-clients.sh"
  },
  "private": true,
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <12"
