# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://servicecore:servicecore@localhost:5432/servicecore"
REDIS_URL="redis://localhost:6379"

# ─── Kimai ────────────────────────────────────────────────────────────────────
KIMAI_BASE_URL="http://localhost:8001"
KIMAI_API_TOKEN="your-kimai-api-token"

# ─── TimeTrex ─────────────────────────────────────────────────────────────────
TIMETREX_BASE_URL="http://localhost:8002"
TIMETREX_API_TOKEN="your-timetrex-api-token"
TIMETREX_API_MODE="rest"
TIMETREX_RPC_VERSION="2"
TIMETREX_AUTH_MODE="env_session"
TIMETREX_AUTH_TTL_MS="1800000"
TIMETREX_USERNAME="your-timetrex-username"
TIMETREX_PASSWORD="your-timetrex-password"
TIMETREX_LOGIN_LANGUAGE="en"
TIMETREX_SESSION_COOKIE="SessionID=your-session-id; CSRF-Token=your-csrf-token"
TIMETREX_CSRF_TOKEN="your-csrf-token"
TIMETREX_INTEGRATION_ENABLED="false"

# ─── ServiceCore Dispatch API ─────────────────────────────────────────────────
SERVICECORE_API_URL="https://api.servicecore.com"
SERVICECORE_API_KEY="your-servicecore-api-key"

# ─── AI / Genkit ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="your-anthropic-api-key"
GOOGLE_GENAI_API_KEY="your-google-ai-api-key"
GENKIT_ENV="dev"

# ─── Communications ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID="your-twilio-sid"
TWILIO_AUTH_TOKEN="your-twilio-token"
TWILIO_PHONE_NUMBER="+1XXXXXXXXXX"
SENDGRID_API_KEY="your-sendgrid-api-key"

# ─── QuickBooks ───────────────────────────────────────────────────────────────
QBO_CLIENT_ID="your-qbo-client-id"
QBO_CLIENT_SECRET="your-qbo-client-secret"
QBO_REDIRECT_URI="http://localhost:3000/auth/qbo/callback"
QBO_ENVIRONMENT="sandbox"

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="minimum-32-character-random-string-change-me"
JWT_REFRESH_SECRET="different-minimum-32-character-string-change-me"
REQUIRE_API_KEY="false"

# ─── Plaid (EWA) ─────────────────────────────────────────────────────────────
PLAID_CLIENT_ID="your-plaid-client-id"
PLAID_SECRET="your-plaid-secret"
PLAID_ENV="sandbox"

# ─── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID="your-firebase-project"

# ─── Anomaly Detection Service ────────────────────────────────────────────────
ANOMALY_SERVICE_URL="http://localhost:8003"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"
RATE_LIMIT_AUTH_LOGIN_MAX=5
RATE_LIMIT_AUTH_REFRESH_MAX=20
RATE_LIMIT_AI_MAX=60
